# =========================================
# ベースイメージ: Node.js 20の軽量版
# =========================================
FROM node:20-slim

WORKDIR /app

# =========================================
# パッケージのインストール
# package.json/package-lock.jsonだけ先にコピーすることで、
# コード変更時に毎回 npm install しなくて済む(Dockerのキャッシュ活用)
# =========================================
COPY package.json package-lock.json* ./
RUN npm install

# =========================================
# アプリのコードをコピー
# =========================================
COPY . .

# Next.jsの開発サーバーがリッスンするポート
EXPOSE 3000

# =========================================
# コンテナ起動時に実行するコマンド(開発モード)
# =========================================
CMD ["npm", "run", "dev"]