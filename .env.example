# =========================================
# このファイルは「テンプレート」です
# コピーして .env を作成し、実際の値を入れてください
#
# 使い方:
#   cp .env.example .env
#   その後 .env の中身を自分の値に書き換える
# =========================================

# --- データベース接続情報 ---
POSTGRES_USER=fxsignal_user
POSTGRES_PASSWORD=
POSTGRES_DB=fxsignal_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://fxsignal_user:__POSTGRES_PASSWORD__@db:5432/fxsignal_db

# --- Twelve Data API(価格データ取得) ---
# 取得先: https://twelvedata.com/
TWELVE_DATA_API_KEY=

# --- Discord Webhook(通知) ---
# Discordサーバー設定 > 連携サービス > ウェブフック で作成
DISCORD_WEBHOOK_URL=

# --- 認証 ---
SECRET_KEY=

# --- アプリ動作設定 ---
ENVIRONMENT=development
POLLING_INTERVAL_SECONDS=300
