# =========================================
# ベースイメージ: Python 3.11の軽量版
# =========================================
FROM python:3.11-slim

# コンテナ内の作業ディレクトリ
WORKDIR /app

# =========================================
# システムパッケージのインストール
# psycopg2(PostgreSQLドライバ)のビルドに必要
# =========================================
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# =========================================
# Pythonパッケージのインストール
# 先にrequirements.txtだけコピーしてインストールすることで、
# コード変更時に毎回パッケージを再インストールしなくて済む(Dockerのキャッシュ活用)
# =========================================
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# =========================================
# アプリのコードをコピー
# =========================================
COPY . .

# FastAPIがリッスンするポート
EXPOSE 8000

# =========================================
# コンテナ起動時に実行するコマンド
# --reload: コード変更時に自動でサーバーを再起動(開発用)
# --host 0.0.0.0: コンテナ外からのアクセスを許可
# =========================================
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
